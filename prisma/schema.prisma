datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model Card {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  jobTitle     String?
  company      String?
  profileImage String?
  coverImage   String?
  companyLogo  String?
  themeColor   String   @default("#1A171B")

  mobile       String?
  email        String?
  sms          String?
  whatsapp     String?

  addressTitle String?
  street       String?
  city         String?
  zip          String?
  addressUrl   String?

  links        Link[]
  socials      Social[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Link {
  id       String @id @default(cuid())
  title    String
  url      String
  iconUrl  String?
  card     Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  cardId   String
}

model Social {
  id       String @id @default(cuid())
  platform String
  url      String
  iconUrl  String?
  card     Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  cardId   String
}
